# Optional API keys — adapters degrade gracefully when absent.
# Copy to .env and fill in only what you have.

# DART (한국 전자공시) - https://opendart.fss.or.kr/
DART_API_KEY=

# FRED (US macro) - https://fred.stlouisfed.org/docs/api/api_key.html
# Free tier works without key via CSV download; key gives higher rate limits.
FRED_API_KEY=

# Finnhub (US/global consensus) - https://finnhub.io/
FINNHUB_API_KEY=
